@page "/referees"
@inject RefereeService RefereeService
@inject NavigationManager Nav

<PageTitle>@L["referees.pageTitle"]</PageTitle>

@* ── Page Header ── *@
<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;flex-wrap:wrap;gap:16px;">
    <div>
        <h1 style="font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;margin-bottom:4px;">
            @L["referees.title"]
        </h1>
        <p style="font-size:.85rem;color:var(--text-muted);font-weight:300;">
            @L["referees.subtitle"]
        </p>
    </div>
    <div style="display:flex;gap:12px;">
        <MiniStat Value="@Counts.total.ToString()" Label="Total" Color="var(--accent-cyan)" />
        <MiniStat Value="@Counts.active.ToString()" Label="Active" Color="var(--accent-lime)" />
        <MiniStat Value="@Counts.probation.ToString()" Label="Probation" Color="var(--accent-orange)" />
        <MiniStat Value="@Counts.inactive.ToString()" Label="Inactive" Color="var(--accent-red)" />
    </div>
</div>

@* ── Filters & Search ── *@
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:14px;">
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
        <FilterBar Options="StatusFilters" ActiveFilter="@ActiveStatusFilter"
                   ActiveFilterChanged="OnStatusFilterChanged" />
        <span style="width:1px;height:24px;background:var(--border-subtle);margin:0 4px;"></span>
        <FilterBar Options="TierFilters" ActiveFilter="@ActiveTierFilter"
                   ActiveFilterChanged="OnTierFilterChanged" />
    </div>
    <div class="search-input-wrap" style="width:280px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" class="search-input" placeholder="Search by name, ID, location..."
               @bind="SearchQuery" @bind:event="oninput" @bind:after="ApplyFiltersAsync" />
    </div>
</div>

@* ── Registry Table ── *@
<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>@L["common.th.referee"]</th><th>@L["referees.th.dobAge"]</th><th>@L["referees.th.location"]</th><th>@L["referees.form.tier"]</th>
                <th>@L["referees.form.status"]</th><th>@L["referees.th.registered"]</th><th>@L["common.th.matches"]</th><th>@L["common.th.actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in FilteredReferees)
            {
                <tr>
                    <td>
                        <div class="table-name-cell">
                            <AvatarPlaceholder Initials="@r.Initials" />
                            <div>
                                <div class="table-name">@r.FullName</div>
                                <div class="table-name-sub">@r.RefCode</div>
                            </div>
                        </div>
                    </td>
                    <td style="font-size:.82rem;">
                        <span style="color:var(--text-primary);">@r.DateOfBirth.ToString("dd MMM yyyy")</span><br/>
                        <span style="color:var(--text-dim);font-size:.72rem;">Age @r.Age</span>
                    </td>
                    <td style="font-size:.82rem;color:var(--text-muted);">@r.Location</td>
                    <td><TierBadge Tier="r.Tier" /></td>
                    <td><StatusBadge Status="r.Status" /></td>
                    <td style="font-size:.82rem;color:var(--text-muted);">@r.RegistrationDate.ToString("dd MMM yyyy")</td>
                    <td style="font-family:'JetBrains Mono',monospace;font-size:.82rem;">@r.TotalMatches</td>
                    <td>
                        <div style="display:flex;gap:4px;">
                            <button class="btn btn-ghost btn-icon" title="View Profile"
                                    @onclick="() => ViewReferee(r.Id)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                            <button class="btn btn-ghost btn-icon" title="Edit"
                                    @onclick="() => OpenEditModal(r)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                            </button>
                            <button class="btn btn-ghost btn-icon" title="Delete"
                                    style="color:var(--accent-red);"
                                    @onclick="() => OpenDeleteConfirm(r)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
                                    <polyline points="3 6 5 6 21 6"/>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                </svg>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="table-footer">
        <span>Showing @FilteredReferees.Count of @AllReferees.Count referees</span>
        <div class="pagination">
            <button>‹</button><button class="active">1</button><button>›</button>
        </div>
    </div>
</div>

@* ── Add/Edit Modal ── *@
<RefereeFormModal IsOpen="FormModalOpen" Model="FormModel"
                  OnSubmit="HandleFormSubmit" OnCancel="CloseFormModal" />

@* ── Delete Confirmation ── *@
<ConfirmDialog IsOpen="DeleteDialogOpen"
               Title=@L["referees.deleteConfirmTitle"]
               Message="Remove Referee?"
               Description=@L["referees.deleteConfirmMsg"].Replace("{Name}", DeletingReferee?.FullName)
               ConfirmLabel=@L["referees.deleteConfirmAction"]
               OnConfirm="HandleDelete" OnCancel="CloseDeleteDialog" />

@code {
    private List<Referee> AllReferees = new();
    private List<Referee> FilteredReferees = new();
    private (int total, int active, int probation, int inactive) Counts;

    // Filters
    private string SearchQuery = "";
    private string ActiveStatusFilter = "All";
    private string ActiveTierFilter = "All Tiers";
    private static readonly List<string> StatusFilters = new() { "All", "Active", "Inactive", "Probation", "Suspended" };
    private static readonly List<string> TierFilters = new() { "All Tiers", "FIFA", "Premier", "Championship", "League 1+" };

    // Form modal
    private bool FormModalOpen;
    private RefereeFormModel FormModel = new();

    // Delete dialog
    private bool DeleteDialogOpen;
    private Referee? DeletingReferee;

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private void ViewReferee(int id) => Nav.NavigateTo($"/referees/{id}");

    private async Task LoadDataAsync()
    {
        AllReferees = await RefereeService.GetAllRefereesAsync();
        Counts = await RefereeService.GetStatusCountsAsync();
        await ApplyFiltersAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        RefereeStatus? statusFilter = ActiveStatusFilter switch
        {
            "Active" => RefereeStatus.Active,
            "Inactive" => RefereeStatus.Inactive,
            "Probation" => RefereeStatus.Probation,
            "Suspended" => RefereeStatus.Suspended,
            _ => null
        };

        RefereeTier? tierFilter = ActiveTierFilter switch
        {
            "FIFA" => RefereeTier.FifaInternational,
            "Premier" => RefereeTier.PremierLeague,
            "Championship" => RefereeTier.Championship,
            "League 1+" => RefereeTier.LeagueOne,
            _ => null
        };

        FilteredReferees = await RefereeService.SearchRefereesAsync(SearchQuery, tierFilter, statusFilter);
    }

    private async Task OnStatusFilterChanged(string filter) { ActiveStatusFilter = filter; await ApplyFiltersAsync(); }
    private async Task OnTierFilterChanged(string filter) { ActiveTierFilter = filter; await ApplyFiltersAsync(); }

    // ── Add / Edit ──
    public void OpenAddModal()
    {
        FormModel = new RefereeFormModel();
        FormModalOpen = true;
    }

    private void OpenEditModal(Referee r)
    {
        FormModel = RefereeFormModel.FromReferee(r);
        FormModalOpen = true;
    }

    private void CloseFormModal() => FormModalOpen = false;

    private async Task HandleFormSubmit(RefereeFormModel model)
    {
        if (model.IsEdit)
            await RefereeService.UpdateRefereeAsync(model);
        else
            await RefereeService.AddRefereeAsync(model);

        FormModalOpen = false;
        await LoadDataAsync();
    }

    // ── Delete ──
    private void OpenDeleteConfirm(Referee r)
    {
        DeletingReferee = r;
        DeleteDialogOpen = true;
    }

    private void CloseDeleteDialog() => DeleteDialogOpen = false;

    private async Task HandleDelete()
    {
        if (DeletingReferee != null)
            await RefereeService.DeleteRefereeAsync(DeletingReferee.Id);
        DeleteDialogOpen = false;
        DeletingReferee = null;
        await LoadDataAsync();
    }
}

