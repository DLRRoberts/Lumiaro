@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject RefereeService RefereeService
@implements IDisposable

<div class="app-layout">

    <aside class="sidebar @(SidebarOpen ? "open" : "")" id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/></svg>
            </div>
            <div>
                <div class="sidebar-brand-text">Lumiaro</div>
                <div class="sidebar-brand-sub">@L["app.subtitle"]</div>
            </div>
        </div>

        <div class="sidebar-nav">
            <div class="sidebar-section-label">@L["nav.overview"]</div>
            <NavLink href="" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                @L["nav.dashboard"]
            </NavLink>

            <div class="sidebar-section-label">@L["nav.management"]</div>
            <NavLink href="referees" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                @L["nav.referees"]
                <span class="nav-badge">@CurrentReferees</span>
            </NavLink>
            <NavLink href="fixtures" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                @L["nav.fixtures"]
            </NavLink>
            <NavLink href="assessments" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                @L["nav.assessments"]
            </NavLink>
            <NavLink href="reports" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                @L["nav.reports"]
            </NavLink>
            <NavLink href="match-validation" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><circle cx="12" cy="12" r="10"/></svg>
                Match Validation
            </NavLink>

            <div class="sidebar-section-label">@L["nav.intelligence"]</div>
            <NavLink href="search" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                @L["nav.search"]
            </NavLink>
            <NavLink href="analytics" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 17l4-8 4 4 6-10"/></svg>
                @L["nav.analytics"]
            </NavLink>
            <NavLink href="benchmarking" @onclick="CloseSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                @L["nav.benchmarking"]
            </NavLink>

            <div class="sidebar-section-label">@L["nav.system"]</div>
            <button class="sidebar-nav-btn" style="width:24px;height:24px;background-color:transparent;" @onclick="OpenSettings">
                <svg viewBox="0 0 24 24" fill="none" stroke="White" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </button>
        </div>

        <div class="sidebar-footer">
            <div class="sidebar-avatar">DA</div>
            <div>
                <div class="sidebar-user-name">Dominic R.</div>
                <div class="sidebar-user-role">System Administrator</div>
            </div>
        </div>
    </aside>

    <header class="app-header">
        <div style="display:flex;align-items:center;gap:16px;">
            <button class="mobile-menu-btn" @onclick="ToggleSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
            <div class="header-breadcrumb">
                @if (Breadcrumbs?.Any() == true)
                {
                    @foreach (var (label, href, isLast) in GetBreadcrumbItems())
                    {
                        @if (isLast)
                        {
                            <span class="current">@label</span>
                        }
                        else
                        {
                            <a href="@href">@label</a>
                            <span class="sep">›</span>
                        }
                    }
                }
                else
                {
                    <span class="current">@PageTitle</span>
                }
            </div>
        </div>
        <div class="header-actions">
            <button class="header-lang-btn" @onclick="OpenSettings" title="@L["settings.language"]">
                @LanguageFlag
                <span>@L.CurrentLanguageLabel</span>
            </button>
            @HeaderActions
        </div>
    </header>

    <main class="app-main">
        @Body
    </main>

</div>

@if (SidebarOpen)
{
    <div class="sidebar-overlay" @onclick="CloseSidebar"></div>
}

<SettingsModal IsOpen="SettingsOpen" OnClose="CloseSettings" />

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    // Page-level customisation via cascading values
    private bool SidebarOpen { get; set; }
    private bool SettingsOpen { get; set; }
    
    private int CurrentReferees { get; set; }
    

    // These can be set by child pages
    [Parameter] public string PageTitle { get; set; } = "Dashboard";
    [Parameter] public List<(string Label, string Href)>? Breadcrumbs { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    
    private string LanguageFlag => L.AvailableLanguages
        .FirstOrDefault(l => l.Code == L.CurrentLanguage).Flag ?? "🇬🇧";

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    private void ToggleSidebar() => SidebarOpen = !SidebarOpen;
    private void CloseSidebar() => SidebarOpen = false;

    protected override async Task OnInitializedAsync()
    {
        CurrentReferees = await RefereeService.GetRefereeCount();
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await L.InitializeAsync();

            L.OnLanguageChanged += HandleLanguageChanged;

            StateHasChanged();
        }
    }
    
    private void OpenSettings()
    {
        SettingsOpen = true;
        SidebarOpen = false;
    }

    private void CloseSettings() => SettingsOpen = false;

    private IEnumerable<(string Label, string Href, bool IsLast)> GetBreadcrumbItems()
    {
        if (Breadcrumbs == null) yield break;
        for (int i = 0; i < Breadcrumbs.Count; i++)
        {
            yield return (Breadcrumbs[i].Label, Breadcrumbs[i].Href, i == Breadcrumbs.Count - 1);
        }
    }
    
    public void Dispose()
    {
        L.OnLanguageChanged -= HandleLanguageChanged;
    }
}
