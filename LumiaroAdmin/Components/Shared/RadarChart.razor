@using LumiaroAdmin.Models

<div class="radar-chart-container">
    <svg viewBox="0 0 @Size @Size" class="radar-chart-svg">
        @{
            var cx = Size / 2.0;
            var cy = Size / 2.0;
            var maxR = Size / 2.0 - Padding;
            var points = Data?.GetRadarPoints() ?? new();
            var n = points.Count;
            if (n < 3) n = 6;
        }

        @* Grid rings *@
        @for (int ring = 1; ring <= 5; ring++)
        {
            var r = maxR * ring / 5.0;
            var ringPoints = new List<string>();
            for (int i = 0; i < n; i++)
            {
                var angle = Math.PI * 2 * i / n - Math.PI / 2;
                ringPoints.Add($"{cx + r * Math.Cos(angle):F1},{cy + r * Math.Sin(angle):F1}");
            }
            <polygon points="@string.Join(" ", ringPoints)"
                     fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="1" />
        }

        @* Axis lines *@
        @for (int i = 0; i < n; i++)
        {
            var angle = Math.PI * 2 * i / n - Math.PI / 2;
            var x2 = cx + maxR * Math.Cos(angle);
            var y2 = cy + maxR * Math.Sin(angle);
            <line x1="@cx.ToString("F1")" y1="@cy.ToString("F1")"
                  x2="@x2.ToString("F1")" y2="@y2.ToString("F1")"
                  stroke="rgba(255,255,255,0.1)" stroke-width="1" />
        }

        @* Data polygon *@
        @if (points.Count >= 3)
        {
            var dataPoints = new List<string>();
            for (int i = 0; i < points.Count; i++)
            {
                var angle = Math.PI * 2 * i / points.Count - Math.PI / 2;
                var val = Math.Max(0, Math.Min(10, points[i].Value));
                var r = maxR * val / 10.0;
                dataPoints.Add($"{(cx + r * Math.Cos(angle)):F1},{(cy + r * Math.Sin(angle)):F1}");
            }
            <polygon points="@string.Join(" ", dataPoints)"
                     fill="rgba(0,255,157,0.15)" stroke="var(--accent-lime)" stroke-width="2" />

            @* Data points *@
            @for (int i = 0; i < points.Count; i++)
            {
                var angle = Math.PI * 2 * i / points.Count - Math.PI / 2;
                var val = Math.Max(0, Math.Min(10, points[i].Value));
                var r = maxR * val / 10.0;
                var px = cx + r * Math.Cos(angle);
                var py = cy + r * Math.Sin(angle);
                <circle cx="@px.ToString("F1")" cy="@py.ToString("F1")" r="4"
                        fill="var(--accent-lime)" stroke="var(--panel-card)" stroke-width="2" />
            }

            @* Labels *@
            @for (int i = 0; i < points.Count; i++)
            {
                var angle = Math.PI * 2 * i / points.Count - Math.PI / 2;
                var lx = cx + (maxR + 28) * Math.Cos(angle);
                var ly = cy + (maxR + 28) * Math.Sin(angle);
                var anchor = Math.Abs(Math.Cos(angle)) < 0.1 ? "middle"
                    : Math.Cos(angle) > 0 ? "start" : "end";
                <text><text x="@lx.ToString("F1")" y="@ly.ToString("F1")"
                      text-anchor="@anchor" dominant-baseline="central"
                      class="radar-label">@points[i].Label</text></text>
                <text><text x="@lx.ToString("F1")" y="@((ly + 14).ToString("F1"))"
                      text-anchor="@anchor" dominant-baseline="central"
                      class="radar-value" fill="@UiHelpers.ScoreColor(points[i].Value)">
                    @points[i].Value.ToString("F1")
                    </text></text>
            }
        }
    </svg>
</div>

@code {
    [Parameter] public CompetencyRadarData? Data { get; set; }
    [Parameter] public int Size { get; set; } = 340;
    [Parameter] public int Padding { get; set; } = 50;
}
