@namespace Lumiaro.MatchValidation.Components.Shared
@using Lumiaro.MatchValidation.Models

@if (Charge is not null && CardType is not null)
{
    <div class="charge-strip on">
        <span class="cs-code @CodeClass">@Charge.Code</span>
        <span class="cs-desc">@DescriptionText</span>
        <span class="cs-lock">@LockText</span>
    </div>
}

@code {
    [Parameter] public CardType? CardType { get; set; }
    [Parameter] public ChargeCode? Charge { get; set; }
    [Parameter] public Offence? Offence { get; set; }

    private bool IsYellowFamily =>
        CardType is Models.CardType.Yellow or Models.CardType.SecondYellow;

    private string CodeClass => IsYellowFamily ? "cs-yellow" : "cs-red";

    private string DescriptionText =>
        Offence is null
            ? Charge?.Description ?? string.Empty
            : $"{Charge?.Description} · {Offence.Label}";

    private string LockText
    {
        get
        {
            if (Charge is null)             return string.Empty;
            if (!Charge.RequiresOffence)    return "✓ Locked";
            if (Offence is null)            return "Select offence";
            return "✓ Selected";
        }
    }
}
